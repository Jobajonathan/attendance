NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (never expose with a NEXT_PUBLIC_ prefix). Used by the Vercel Cron
# job that transitions activity status (FR-ATT-03). Get the service role key from
# Supabase dashboard -> Project Settings -> API -> service_role secret.
SUPABASE_SERVICE_ROLE_KEY=
# Any random string; also set the same value as the "Authorization: Bearer <value>"
# Vercel sends its Cron requests with when CRON_SECRET is configured.
CRON_SECRET=
